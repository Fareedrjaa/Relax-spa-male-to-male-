rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Schema Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'createdAt'])
        && (data.keys().size() >= 5 && data.keys().size() <= 7)
        && data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 512
        && data.displayName is string && data.displayName.size() <= 256
        && data.photoURL is string && data.photoURL.size() <= 3072
        && data.createdAt is string && data.createdAt.size() <= 128
        && (!('loyaltyPoints' in data) || data.loyaltyPoints is int);
    }

    function isValidHabitLog(data) {
      return data.keys().hasAll(['userId', 'activity', 'date', 'rewardPoints', 'createdAt'])
        && data.keys().size() == 5
        && data.userId is string && data.userId == request.auth.uid
        && data.activity is string && data.activity.size() <= 128
        && data.date is string && data.date.size() <= 32
        && data.rewardPoints is int
        && data.createdAt is string && data.createdAt.size() <= 128;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'customerName', 'phoneNumber', 'selectedService', 'serviceMode', 'bookingDate', 'bookingTime', 'status', 'createdAt'])
        && (data.keys().size() == 10 || data.keys().size() == 11 || data.keys().size() == 9)
        && data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid
        && data.customerName is string && data.customerName.size() >= 2 && data.customerName.size() <= 128
        && data.phoneNumber is string && data.phoneNumber.size() >= 8 && data.phoneNumber.size() <= 20
        && data.selectedService is string && data.selectedService.size() <= 128
        && data.serviceMode is string && (data.serviceMode == 'spa' || data.serviceMode == 'home')
        && data.bookingDate is string && data.bookingDate.size() <= 128
        && data.bookingTime is string && data.bookingTime.size() <= 128
        && (!('homeAddress' in data) || (data.homeAddress is string && data.homeAddress.size() <= 512))
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 1024))
        && data.status is string && (data.status == 'pending' || data.status == 'confirmed' || data.status == 'completed')
        && data.createdAt is string && data.createdAt.size() <= 128;
    }

    // Users Collection rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(incoming());
      allow delete: if isOwner(userId);

      // Subcollection for habitLogs
      match /habitLogs/{logId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidHabitLog(incoming());
        allow delete: if isOwner(userId);
      }
    }

    // Bookings Collection rules
    match /bookings/{bookingId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      // List query enforcer rule - forces safe query boundaries
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidBooking(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidBooking(incoming()) && (
        // Enforce the fields that are allowed to change (e.g. status or notes)
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'notes', 'bookingDate', 'bookingTime'])
      );
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Support collection for validating Firestore connection upon initialization
    match /test/{testId} {
      allow get: if true;
    }
  }
}
